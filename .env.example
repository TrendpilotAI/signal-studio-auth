# ============================================================
# signal-studio-auth — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values before
# starting the service.
#
#   cp .env.example .env
#
# NEVER commit a populated .env file — it contains secrets.
# ============================================================


# ------------------------------------------------------------
# Supabase (REQUIRED)
# ------------------------------------------------------------

# Your Supabase project URL.
# Found in: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (admin privileges — keep server-side only).
# Found in: Supabase Dashboard → Settings → API → service_role key
# WARNING: Do not expose this key to clients or commit it to source control.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# JWT secret used to verify Supabase-issued access tokens.
# Found in: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-at-least-32-chars


# ------------------------------------------------------------
# Auth / JWT (REQUIRED)
# ------------------------------------------------------------

# Strong secret used for legacy ForwardLane / dual auth mode JWT validation.
# Must be a cryptographically random string of at least 32 characters.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# Also referred to as JWT_SECRET in other services in the Signal Studio stack.
AUTH_SECRET_KEY=replace-with-a-cryptographically-random-secret-min-32-chars

# Alias — some tooling and documentation refer to this as JWT_SECRET.
# Set either AUTH_SECRET_KEY or JWT_SECRET; the service reads AUTH_SECRET_KEY.
# JWT_SECRET=replace-with-a-cryptographically-random-secret-min-32-chars


# ------------------------------------------------------------
# Redis (optional — strongly recommended in production)
# ------------------------------------------------------------

# Redis connection URL.
# If not set, the service falls back to in-memory storage for:
#   - sliding-window rate limiting
#   - opaque refresh token rotation and family tracking
# In-memory mode is safe for single-instance local dev but NOT for
# multi-replica production deployments.
#
# Local dev:  redis://localhost:6379/0
# Railway:    set via Railway Redis plugin → $REDIS_URL (auto-injected)
# Render:     set via Render Redis add-on
REDIS_URL=redis://localhost:6379/0


# ------------------------------------------------------------
# CORS (optional)
# ------------------------------------------------------------

# Comma-separated list of allowed origins for CORS.
# Example: https://app.example.com,https://staging.example.com
# Leave unset to disable CORS (default: no origins allowed).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173


# ------------------------------------------------------------
# Auth mode (optional)
# ------------------------------------------------------------

# Controls which authentication backends are active.
# Options:
#   supabase     — Supabase Auth only (recommended for new deployments)
#   forwardlane  — Legacy ForwardLane JWT only
#   dual         — Accept both Supabase and ForwardLane tokens (default)
AUTH_MODE=supabase


# ------------------------------------------------------------
# Legacy ForwardLane (optional — only needed in dual/forwardlane mode)
# ------------------------------------------------------------

# Base URL of the legacy ForwardLane API used for token validation.
# Only required when AUTH_MODE=forwardlane or AUTH_MODE=dual.
FORWARDLANE_API_URL=http://0.0.0.0:8000
