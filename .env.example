# ---------------------------------------------------------------------------
# signal-studio-auth — Environment Variables (TODO-827)
# Copy this file to .env and fill in real values before running the service.
# ---------------------------------------------------------------------------

# ── Supabase ────────────────────────────────────────────────────────────────
# Your Supabase project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# JWT secret from Supabase project settings → API → JWT Secret
# Must be at least 32 characters
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-min-32-chars

# Service role key (admin operations only — keep secret!)
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── Auth mode ───────────────────────────────────────────────────────────────
# One of: supabase | forwardlane | dual
AUTH_MODE=dual

# ── ForwardLane (legacy) ────────────────────────────────────────────────────
# ForwardLane API base URL
FORWARDLANE_API_URL=http://0.0.0.0:8000

# Legacy JWT secret — required in forwardlane / dual mode (min 32 chars)
AUTH_SECRET_KEY=your-forwardlane-jwt-secret-min-32-chars

# ── Redis ───────────────────────────────────────────────────────────────────
# Redis connection URL. Leave blank to run in in-memory fallback mode.
# When using docker-compose the value below is set automatically via the
# `environment` block; override here only if pointing at an external Redis.
REDIS_URL=redis://redis:6379/0

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (TODO-826).
# Example: https://app.example.com,https://admin.example.com
# Leave blank to disallow all cross-origin requests.
CORS_ALLOWED_ORIGINS=

# ── Misc ────────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
